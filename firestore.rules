rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /ai_debug_logs/{scopeKey}/{document=**} {
      // Device-scoped logs: any client can read/write (device ID can't be verified server-side)
      allow read, write: if scopeKey.matches('device_[a-zA-Z0-9_\\-]+');

      // UID-scoped logs: only the authenticated user matching their own UID
      allow read, write: if request.auth != null
        && scopeKey == ('uid_' + request.auth.uid);

      // ID-scoped logs: any authenticated user (custom backend identifier)
      allow read, write: if request.auth != null
        && scopeKey.matches('id_[a-zA-Z0-9_\\-]+');
    }
  }
}
