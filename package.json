  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "verify:alerts": "bash scripts/verify-alerts.sh",
    "test:day-budget": "node scripts/run-day-budget-tests.cjs",
    "test:ranking": "node scripts/run-recommendation-ranking-tests.cjs",
    "test:today-alert": "node scripts/run-today-alert-tests.cjs",
    "test:menu-validation": "node scripts/run-menu-validator-tests.cjs",
    "ai-debug:sink": "node scripts/ai-debug-local-sink.mjs",
    "ai-debug:scan": "node scripts/ai-debug-read-by-scan.mjs",
    "check": "npm run typecheck && npm run verify:alerts && npm run test:menu-validation && echo \"✅ Check passed. Run 'npm start' to test in simulator. See UI_QA.md for checklist.\""
  },
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@react-native-async-storage/async-storage": "2.2.0",
