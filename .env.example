EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_google_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_google_client_id
EXPO_PUBLIC_TERMS_URL=https://your-domain.com/terms
