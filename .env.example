EXPO_PUBLIC_GEMINI_API_KEY=your_key_here
# Optional: primary model for AI calls when specific chain is not set
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash
# Optional: explicit model chain for menu scan (comma-separated)
# EXPO_PUBLIC_GEMINI_MENU_SCAN_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
# Optional: extra downgrade models tried only when a model hits 429 (comma-separated)
# EXPO_PUBLIC_GEMINI_RATE_LIMIT_DOWNGRADE_MODELS=gemini-2.0-flash-lite
# Optional if using your own backend auth service
# EXPO_PUBLIC_API_BASE_URL=https://api.your-backend.com

# Firebase Auth fallback (used when EXPO_PUBLIC_API_BASE_URL is not set)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
# Optional: upload AI debug logs to Firestore for cross-device scan diagnostics
# EXPO_PUBLIC_AI_DEBUG_FIREBASE_SYNC=true
# Optional: send AI debug logs to local sink server (writes files under .tmp/ai_debug_local_sink)
# EXPO_PUBLIC_AI_DEBUG_LOCAL_SINK_URL=http://127.0.0.1:8787
# Optional Firebase fields
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
# EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Apple-only auth mode (default in code is true)
EXPO_PUBLIC_AUTH_APPLE_ONLY=true
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_google_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_google_client_id
EXPO_PUBLIC_TERMS_URL=https://your-domain.com/terms
EXPO_PUBLIC_PRIVACY_URL=https://your-domain.com/privacy
EXPO_PUBLIC_DELETE_ACCOUNT_URL=https://your-domain.com/account/delete
# Optional
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_google_client_id
# Optional: set to true or 1 to show mock data on Home/Profile/Menu results when no real data exists
# EXPO_PUBLIC_USE_MOCK_DATA=true
